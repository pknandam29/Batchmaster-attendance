rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == 'naprku@gmail.com'
      );
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Entity Validations ---

    function isValidBatch(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.startDate is string && // Simplified for now, could be timestamp
             data.keys().hasAll(['name', 'startDate', 'createdAt']) &&
             data.keys().size() <= 6; // name, startDate, createdAt, studentCount, averageAttendance, description
    }

    function isValidStudent(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             isValidId(data.batchId) &&
             data.keys().hasAll(['name', 'batchId', 'createdAt']) &&
             data.keys().size() <= 5;
    }

    function isValidSession(data) {
      return isValidId(data.batchId) &&
             data.sessionNumber is int && data.sessionNumber >= 1 && data.sessionNumber <= 12 &&
             data.keys().hasAll(['batchId', 'sessionNumber', 'date']) &&
             data.keys().size() <= 6;
    }

    function isValidAttendance(data) {
      return isValidId(data.studentId) &&
             isValidId(data.sessionId) &&
             isValidId(data.batchId) &&
             data.status in ['present', 'absent'] &&
             data.keys().hasAll(['studentId', 'sessionId', 'batchId', 'status', 'markedAt']);
    }

    // --- Collection Rules ---

    match /batches/{batchId} {
      allow read: if isSignedIn();
      allow create: if isAdmin() && isValidBatch(incoming()) && isValidId(batchId);
      allow update: if (isAdmin() || isSignedIn()) && 
                    isValidBatch(incoming()) && (
                      isAdmin() || 
                      (incoming().diff(existing()).affectedKeys().hasOnly(['studentCount', 'averageAttendance']))
                    );
      allow delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidStudent(incoming()) && isValidId(studentId);
      allow update: if isSignedIn() && isValidStudent(incoming()) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['name', 'attendancePercentage']);
      allow delete: if isAdmin();
    }

    match /sessions/{sessionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidSession(incoming()) && isValidId(sessionId);
      allow update: if isSignedIn() && isValidSession(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['date', 'title', 'attendanceCount']);
      allow delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidAttendance(incoming()) && isValidId(attendanceId) &&
                    incoming().markedAt == request.time;
      allow update: if isSignedIn() && isValidAttendance(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['status', 'markedAt']) &&
                    incoming().markedAt == request.time;
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow get: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isOwner(userId) || isAdmin();
    }
    
    match /admins/{userId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via console
    }
  }
}
